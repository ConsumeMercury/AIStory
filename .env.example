# Copy to .env and paste your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Web server (localhost only by default — see SECURITY.md)
# AISTORY_HOST=127.0.0.1
# AISTORY_PORT=8765
# AISTORY_CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Debugging (restart server after changing):
# AISTORY_DEBUG=1              — verbose logs + /api/debug/* + world inspector
# AISTORY_DEBUG_TOKENS=1       — print Gemini prompt token estimates in server console
# AISTORY_STRICT=1             — raise on focal-id invariant violations (CI sets this)
# AISTORY_SKIP_PROSE_VALIDATION=1 — disable live post-generation prose checks (default: log-only on)
# AISTORY_HINTS=plain          — suggestion chip verbosity (off | subtle | plain)
# AISTORY_AUTO_CHAR=1          — skip character creation in CLI (used by verify_all.py)
