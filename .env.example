# Copy to .env and paste your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Web server (localhost only by default — see SECURITY.md)
# AISTORY_HOST=127.0.0.1
# AISTORY_PORT=8765
# AISTORY_CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Debugging (restart server after changing):
# AISTORY_DEBUG=1              — verbose logs + /api/debug/* + world inspector
# AISTORY_DEBUG_TOKENS=1       — print Gemini prompt token estimates in server console
# AISTORY_STRICT=1             — raise on focal-id invariant violations (CI sets this)
# AISTORY_SKIP_PROSE_VALIDATION=1 — disable live post-generation prose checks (default: log-only on)
# AISTORY_PROSE_RETRIES=1 — regenerate scene once when prose_validator finds fact violations (default: 1)
# AISTORY_REGEN_MIN_PRIORITY=40 — skip regen when only low-priority issues remain (0–100)

# Structured contracts (restart server after changing):
# AISTORY_ACTION_CLASSIFIER=off|shadow|on   — LLM action interpreter (recommended: on after shadow validation)
# AISTORY_PROSE_AUDITOR=off|shadow|on         — LLM prose auditor nominations (default: off; keep shadow until graduated)
# AISTORY_BOUNDARY_HISTORY=20               — in-memory boundary metrics ring buffer

# Mock hooks for tests/dev (no API call):
# AISTORY_MOCK_CLASSIFIER_JSON={"kind":"ask_about","target_id":"g1","player_speech":"When?"}
# AISTORY_MOCK_PROSE_AUDITOR_JSON={"violations":[{"type":"speaker_not_in_cast","role_hint":"priest"}]}
# AISTORY_SKIP_MEMORY_BUDGET=1    — disable narrator memory token budgeting
# AISTORY_SKIP_SEMANTIC_MEMORY=1  — keyword-only memory retrieval (no embeddings)
# AISTORY_SKIP_LLM_JOURNAL_SUMMARY=1 — rule-based journal compaction only (no Gemini summary)
# AISTORY_SKIP_FREQUENCY_PENALTY=1  — disable sampling-level lexical repetition penalty
#   (API only applies frequency_penalty on gemini-2.0-*; 2.5+ and 3.x ignore/reject it)
# GEMINI_EMBED_MODEL=gemini-embedding-001 — embedding model for semantic memory (optional)

# Build-time AI world generation (off by default — keeps CI deterministic):
# AISTORY_AI_WORLDGEN=1              — LLM-enrich history + NPC profiles
# AISTORY_AI_WORLDGEN_NPC_BATCH=6    — NPCs per Gemini batch call (1–12, default 6)
# AISTORY_AI_WORLDGEN_NPC_LIMIT=20   — max NPCs to enrich (0 = all 50; default 20 key+crowd)
# AISTORY_AI_WORLDGEN_WORKERS=4      — parallel batch calls (1–8, default 4)
# AISTORY_AI_WORLDGEN_NPC_MAX_TOKENS=4096 — output cap per NPC batch (smaller = faster)
# AISTORY_AI_WORLDGEN_MAX_TOKENS=8192 — output cap for history / large JSON
# AISTORY_AI_WORLDGEN_HISTORY=1      — set 0 to skip history LLM (saves 1 call)
# AISTORY_AI_WORLDGEN_RETRY=0        — set 1 to retry failed NPCs one-by-one (slow)
# AISTORY_AI_WORLDGEN_SPLIT=0        — set 1 to split failed batches recursively (slow)
# AISTORY_AI_WORLDGEN_INSTITUTIONS=0 — set 1 to LLM-enrich institution arcs (off by default)
# AISTORY_AI_WORLDGEN_MAX_INSTITUTIONS=3 — cap when institutions enabled
# AISTORY_AI_WORLDGEN_DISTRICTS=0    — set 1 to LLM-enrich district storylines (off by default)
# AISTORY_AI_WORLDGEN_NAMES=0        — set 1 to let AI rename NPCs during enrichment
# GEMINI_MAX_OUTPUT_TOKENS=8192      — also raises runtime narration cap if unset elsewhere
# AISTORY_HINTS=plain          — suggestion chip verbosity (off | subtle | plain)
# AISTORY_AUTO_CHAR=1          — skip character creation in CLI (used by verify_all.py)
